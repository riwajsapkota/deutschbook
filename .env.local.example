# Copy this file to .env.local and fill in your values.

# Anthropic API — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Database — Turso (cloud SQLite)
# Get at: https://turso.tech → create DB → copy URL and token
# For local dev only (data stays on disk, not shared with production):
#   TURSO_URL=file:data/deutschbook.db
# For local dev that shares data with Vercel deployment:
#   TURSO_URL=libsql://deutschbook-<username>.turso.io
TURSO_URL=libsql://deutschbook-<username>.turso.io
TURSO_AUTH_TOKEN=eyJ...

# Vercel Blob — for storing uploaded lesson files
# Get at: Vercel project → Storage → Blob → Create store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Set to "true" to skip AI calls (useful for fast UI dev)
# MOCK_AI=true
