# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/

# Production
/build

# Environment variables (never commit API keys)
.env
.env.local
.env.*.local

# Database (local data, not for source control)
data/deutschbook.db
data/deutschbook.db-shm
data/deutschbook.db-wal

# Uploaded / processed files (user data) — keep directory structure via .gitkeep
data/uploads/*
!data/uploads/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/exports/*
!data/exports/.gitkeep

# Local dev server log
dev.log

# Personal reading materials (local only)
reading materials/

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS
.DS_Store
*.pem

# Editor
.vscode/
.idea/
*.swp

# Vercel
.vercel

